# ---- Required ----
OPENROUTER_API_KEY=sk-or-...

# ---- Trading mode ----
# Leave false to paper-trade (NO real orders). Flip to true only when you trust it.
REAL_TRADING=false

# Coinbase Advanced Trade CDP API key (only needed when REAL_TRADING=true).
# COINBASE_API_KEY is the key name/id; COINBASE_API_SECRET is the EC private key PEM
# (paste it with literal \n newlines or as a single-quoted multi-line value).
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ---- Model ----
# Any OpenRouter model id. Fires once per minute (~43k calls/month) so pick for cost.
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# ---- What to trade ----
PRODUCTS=BTC-USD,ETH-USD,SOL-USD
QUOTE_CURRENCY=USD

# ---- Cadence ----
INTERVAL_SECONDS=60
CANDLE_LOOKBACK=120

# ---- Risk limits (enforced in code regardless of the LLM) ----
PAPER_START_CASH=10000
MAX_POSITION_USD=1000     # max $ held in any single product
MAX_TRADE_USD=250         # max $ moved in one order
MIN_TRADE_USD=10          # ignore dust
MIN_CASH_RESERVE_USD=100  # never spend below this cash floor
MIN_CONFIDENCE=0.6        # ignore LLM actions below this confidence

# ---- Misc ----
LOG_LEVEL=INFO
