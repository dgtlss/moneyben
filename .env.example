# ---- Required ----
OPENROUTER_API_KEY=sk-or-...
T212_API_KEY=your-trading212-live-api-key
T212_API_SECRET=your-trading212-live-api-secret
T212_DEMO_API_KEY=your-trading212-demo-api-key
T212_DEMO_API_SECRET=your-trading212-demo-api-secret
MARKET_DATA_API_KEY=your-alpha-vantage-api-key

# ---- Trading 212 ----
T212_ENV=demo
TICKERS=AAPL_US_EQ,MSFT_US_EQ,SPY_US_EQ
ALLOWED_INSTRUMENT_TYPES=STOCK,ETF
EXTENDED_HOURS=false

# ---- Market data ----
MARKET_DATA_PROVIDER=twelve_data
MARKET_DATA_BASE_URL=https://api.twelvedata.com
# Optional overrides for non-obvious ticker mappings:
# MARKET_DATA_SYMBOLS=HASl_EQ:HAS.LON,VUSA_UK_EQ:VUSA,BRK.B_US_EQ:BRK.B

# ---- Model ----
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# ---- Cadence ----
INTERVAL_SECONDS=60
CANDLE_LOOKBACK=120
CANDLE_INTERVAL=1min
MAX_PRICE_AGE_SECONDS=300

# ---- Risk limits ----
MAX_POSITION_USD=1000
MAX_TRADE_USD=250
MIN_TRADE_USD=10
MIN_CASH_RESERVE_USD=100
MIN_CONFIDENCE=0.6
QUANTITY_PRECISION=6
READ_ONLY=false

# ---- Shutdown / persistence ----
LIQUIDATE_ON_SHUTDOWN=false
DATA_DIR=/data
LOG_LEVEL=INFO
